{
  "name": "gymplan",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/api",
    "packages/mobile"
  ],
  "scripts": {
    "dev:api": "npm run dev -w packages/api",
    "dev:mobile": "npm run start -w packages/mobile",
    "build:shared": "npm run build -w packages/shared",
    "db:push": "npm run db:push -w packages/api",
    "db:seed": "npm run db:seed -w packages/api",
    "db:generate": "npm run db:generate -w packages/api",
    "typecheck": "npm run typecheck -w packages/shared && npm run typecheck -w packages/api",
    "lint": "eslint packages/*/src --ext .ts,.tsx"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
